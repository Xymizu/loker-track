# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Data source: "memory" (default, no setup needed) or "mysql" (belum aktif)
DATA_SOURCE=memory

# --- Konfigurasi database (isi nanti kalau sudah siap pindah dari memory ke mysql) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=loker_track
